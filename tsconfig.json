{
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "outDir": "./dist/cjs",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "declaration": true,

    "strict": true,
    "strictFunctionTypes": false,

    "lib": ["es2017", "es2015", "es6"],

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
